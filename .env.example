# Copy this file to .env and fill in your token. .env is git-ignored.
#
# The token needs READ-ONLY access to pull requests:
#   - Fine-grained PAT: Repository permissions -> "Pull requests: Read"
#   - Classic PAT:      "repo" scope
#
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# Optional: extra comment authors to treat as bots and hide from previews.
# Accounts GitHub flags as type=Bot (incl. *[bot] and Copilot) are skipped
# automatically; use this for named bot accounts that look like normal users.
# Comma-separated, case-insensitive.
# PR_DIGEST_IGNORE_LOGINS=mycorp-bot,deploy-bot
